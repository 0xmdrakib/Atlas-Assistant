# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_ENABLED=true

# Google login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App URLs
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Database
DATABASE_URL=
DIRECT_URL=

# NOWPayments
# Users can choose any supported crypto on the hosted NOWPayments checkout.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_PRICE_AMOUNT=2.99
NOWPAYMENTS_PRICE_CURRENCY=usd

# MoonPay card-to-crypto bridge
# Card payments need a selected crypto rail. The UI lets users choose from this list.
MOONPAY_PUBLIC_KEY=
MOONPAY_SECRET_KEY=
MOONPAY_CARD_CRYPTO_CODES=usdttrc20,usdc,btc,eth,ltc

# QStash cron protection
QSTASH_NEXT_SIGNING_KEY=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_TOKEN=

# Admin
ADMIN_TOKEN=

# Ingest tuning
INGEST_TRUSTED_RATIO=
INGEST_SOURCE_COOLDOWN_PENALTY=
INGEST_MAX_SOURCES_PER_RUN=
FEED_FETCH_CONCURRENCY=
INGEST_TIMEOUT_MS=
INGEST_DEBUG=
SOURCE_SYNC_ENABLED=
